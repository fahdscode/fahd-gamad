{% comment %}
  Gift-guide banner — top half of the gift-guide landing page.

  Built from scratch for the Figma "Test for Candidates" design:
  - nav row: logo wordmark, centered announcement, yellow CHOOSE GIFT button
  - hero: illustration background, heading, description, black SHOP NOW button
  - bottom strip: single line of uppercase text

  Every piece of copy marked with a red rectangle in the design is a
  customizer setting. On mobile the announcement + button collapse behind a
  hamburger toggle (see assets/gift-guide-banner.js), matching the prototype.
{% endcomment %}

{{ 'section-gift-guide-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-gift-guide-button.css' | asset_url | stylesheet_tag }}
<script src="{{ 'gift-guide-banner.js' | asset_url }}" defer="defer"></script>

<gift-guide-banner class="gift-guide-banner">
  <header class="gift-guide-banner__nav">
    <div class="gift-guide-banner__container gift-guide-banner__nav-inner">
      <button
        class="gift-guide-banner__menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="GiftGuideNavPanel-{{ section.id }}"
        aria-label="{{ 'sections.header.menu' | t }}"
      >
        {%- comment -%} Hamburger / close glyphs; JS only flips aria-expanded. {%- endcomment -%}
        <svg class="gift-guide-banner__icon-hamburger" xmlns="http://www.w3.org/2000/svg" width="18" height="14" viewBox="0 0 18 14" fill="none" aria-hidden="true">
          <path d="M0 1h18M0 7h18M0 13h18" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        <svg class="gift-guide-banner__icon-close" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </button>

      <span class="gift-guide-banner__logo">{{ section.settings.logo_text | escape }}</span>

      <div class="gift-guide-banner__nav-panel" id="GiftGuideNavPanel-{{ section.id }}">
        {%- if section.settings.announcement_text != blank -%}
          <p class="gift-guide-banner__announcement">{{ section.settings.announcement_text | escape }}</p>
        {%- endif -%}
        {%- if section.settings.gift_button_label != blank -%}
          {% render 'gift-guide-button',
            label: section.settings.gift_button_label,
            url: section.settings.gift_button_link,
            style: 'yellow',
            class: 'gift-guide-banner__nav-button'
          %}
        {%- endif -%}
      </div>
    </div>
  </header>

  <div class="gift-guide-banner__hero">
    {%- if section.settings.background_image != blank -%}
      {%- comment -%}
        The illustration is a real <img> (not a CSS background) so the browser
        can pick a responsive candidate; eager + high priority because the
        banner is the page's LCP element.
      {%- endcomment -%}
      <img
        class="gift-guide-banner__hero-image"
        src="{{ section.settings.background_image | image_url: width: 1440 }}"
        srcset="{{ section.settings.background_image | image_url: width: 750 }} 750w,
                {{ section.settings.background_image | image_url: width: 1440 }} 1440w,
                {{ section.settings.background_image | image_url: width: 2880 }} 2880w"
        sizes="100vw"
        width="{{ section.settings.background_image.width }}"
        height="{{ section.settings.background_image.height }}"
        alt=""
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}

    <div class="gift-guide-banner__container gift-guide-banner__hero-inner">
      <div class="gift-guide-banner__hero-content">
        {%- if section.settings.heading != blank -%}
          <h1 class="gift-guide-banner__heading">{{ section.settings.heading | escape }}</h1>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="gift-guide-banner__description">{{ section.settings.description }}</div>
        {%- endif -%}
        {%- if section.settings.shop_button_label != blank -%}
          {% render 'gift-guide-button',
            label: section.settings.shop_button_label,
            url: section.settings.shop_button_link,
            style: 'black',
            class: 'gift-guide-banner__hero-button'
          %}
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- if section.settings.strip_text != blank -%}
    <p class="gift-guide-banner__strip">{{ section.settings.strip_text | escape }}</p>
  {%- endif -%}
</gift-guide-banner>

{% schema %}
{
  "name": "t:sections.gift-guide-banner.name",
  "tag": "section",
  "class": "section-gift-guide-banner",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.gift-guide-banner.settings.header_nav.content"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "t:sections.gift-guide-banner.settings.logo_text.label",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "t:sections.gift-guide-banner.settings.announcement_text.label",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "gift_button_label",
      "label": "t:sections.gift-guide-banner.settings.gift_button_label.label",
      "default": "Choose gift"
    },
    {
      "type": "url",
      "id": "gift_button_link",
      "label": "t:sections.gift-guide-banner.settings.gift_button_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.gift-guide-banner.settings.header_hero.content"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.gift-guide-banner.settings.background_image.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.gift-guide-banner.settings.heading.label",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.gift-guide-banner.settings.description.label",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "shop_button_label",
      "label": "t:sections.gift-guide-banner.settings.shop_button_label.label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "shop_button_link",
      "label": "t:sections.gift-guide-banner.settings.shop_button_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.gift-guide-banner.settings.header_strip.content"
    },
    {
      "type": "text",
      "id": "strip_text",
      "label": "t:sections.gift-guide-banner.settings.strip_text.label",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    }
  ],
  "presets": [
    {
      "name": "t:sections.gift-guide-banner.presets.name"
    }
  ]
}
{% endschema %}
