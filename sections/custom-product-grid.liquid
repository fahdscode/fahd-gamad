{{ 'section-custom-product-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign bundle_product = section.settings.bundle_product
  assign bundle_variant = bundle_product.selected_or_first_available_variant
-%}

<div class="custom-grid color-{{ section.settings.color_scheme }} gradient" id="CustomGrid-{{ section.id }}">
  <div class="custom-grid__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="custom-grid__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <product-grid-popup
      class="custom-grid__grid"
      data-section-id="{{ section.id }}"
      {% if bundle_variant %}
        data-bundle-variant-id="{{ bundle_variant.id }}"
      {% endif %}
    >
      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}
        <div class="custom-grid__item" {{ block.shopify_attributes }}>
          <!-- DEBUG block.id={{ block.id }} settings.product={{ block.settings.product }} product_class={{ product.class }} product_blank={{ product == blank }} -->
          {%- if product != blank -%}
            {%- comment -%}
              Each block embeds its own product/variant data as JSON so the popup
              can be built and populated entirely client-side, with no extra
              network request when a hotspot is clicked.
            {%- endcomment -%}

            <button
              type="button"
              class="custom-grid__hotspot-trigger"
              data-product-json-target="product-data-{{ block.id }}"
              aria-haspopup="dialog"
            >
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | image_url: width: 700 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="700"
                  height="{{ 700.0 | divided_by: product.featured_image.aspect_ratio }}"
                  class="custom-grid__image"
                >
              {%- endif -%}
              <span class="custom-grid__hotspot" aria-hidden="true">+</span>
              <span class="visually-hidden">{{ product.title }}</span>
            </button>

            {%- capture options_json -%}
              [
                {%- for option in product.options_with_values -%}
                  {
                    "name": {{ option.name | json }},
                    "values": {{ option.values | json }}
                  }{% unless forloop.last %},{% endunless %}
                {%- endfor -%}
              ]
            {%- endcapture -%}

            {%- capture variants_json -%}
              [
                {%- for variant in product.variants -%}
                  {
                    "id": {{ variant.id | json }},
                    "available": {{ variant.available | json }},
                    "option1": {{ variant.option1 | json }},
                    "option2": {{ variant.option2 | json }},
                    "option3": {{ variant.option3 | json }},
                    "priceFormatted": {{ variant.price | money | json }}
                  }{% unless forloop.last %},{% endunless %}
                {%- endfor -%}
              ]
            {%- endcapture -%}

            <script type="application/json" id="product-data-{{ block.id }}">
              {
                "title": {{ product.title | json }},
                "description": {{ product.description | strip_html | truncate: 160 | json }},
                "priceFormatted": {{ product.price | money | json }},
                "image": {{ product.featured_image | image_url: width: 400 | json }},
                "options": {{ options_json }},
                "variants": {{ variants_json }}
              }
            </script>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </product-grid-popup>
  </div>

  <dialog class="custom-grid__popup" aria-label="{{ 'products.product.choose_options' | t }}">
    <button type="button" class="custom-grid__popup-close" aria-label="{{ 'accessibility.close' | t }}">&times;</button>

    <div class="custom-grid__popup-media">
      <img class="custom-grid__popup-image" src="" alt="" width="120" height="140">
    </div>

    <div class="custom-grid__popup-content">
      <h3 class="custom-grid__popup-title"></h3>
      <p class="custom-grid__popup-price"></p>
      <p class="custom-grid__popup-description"></p>

      <div class="custom-grid__popup-options"></div>

      <p class="custom-grid__popup-message" role="status" aria-live="polite"></p>

      <button type="button" class="custom-grid__popup-add-to-cart" disabled>
        <span>{{ 'products.product.add_to_cart' | t }}</span>
        <svg width="18" height="12" viewBox="0 0 18 12" fill="none" aria-hidden="true" focusable="false">
          <path
            d="M17.5303 6.53033C17.8232 6.23744 17.8232 5.76256 17.5303 5.46967L12.7574 0.696699C12.4645 0.403806 11.9896 0.403806 11.6967 0.696699C11.4038 0.989593 11.4038 1.46447 11.6967 1.75736L15.9393 6L11.6967 10.2426C11.4038 10.5355 11.4038 11.0104 11.6967 11.3033C11.9896 11.5962 12.4645 11.5962 12.7574 11.3033L17.5303 6.53033ZM0 6.75H17V5.25H0V6.75Z"
            fill="currentColor"
          />
        </svg>
      </button>
    </div>
  </dialog>
</div>

<script src="{{ 'section-custom-product-grid.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.custom-product-grid.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.custom-product-grid.settings.heading.label",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "header",
      "content": "t:sections.custom-product-grid.settings.header_bundle.content",
      "info": "t:sections.custom-product-grid.settings.header_bundle.info"
    },
    {
      "type": "product",
      "id": "bundle_product",
      "label": "t:sections.custom-product-grid.settings.bundle_product.label",
      "info": "t:sections.custom-product-grid.settings.bundle_product.info"
    }
  ],
  "blocks": [
    {
      "type": "product_block",
      "name": "t:sections.custom-product-grid.blocks.product_block.name",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:sections.custom-product-grid.blocks.product_block.settings.product.label"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "t:sections.custom-product-grid.presets.name",
      "blocks": [
        { "type": "product_block" },
        { "type": "product_block" },
        { "type": "product_block" },
        { "type": "product_block" },
        { "type": "product_block" },
        { "type": "product_block" }
      ]
    }
  ]
}
{% endschema %}
