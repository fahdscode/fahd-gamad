{{ 'section-custom-banner.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign gift_link = section.settings.choose_gift_button_link
  assign shop_link = section.settings.shop_now_button_link
-%}

<div class="custom-banner color-{{ section.settings.color_scheme }} gradient" id="CustomBanner-{{ section.id }}">
  <div class="custom-banner__nav">
    <div class="custom-banner__container custom-banner__nav-inner">
      <p class="custom-banner__wordmark">{{ shop.name }}</p>

      {%- if section.settings.nav_announcement_text != blank -%}
        <p class="custom-banner__nav-announcement">{{ section.settings.nav_announcement_text }}</p>
      {%- endif -%}

      {%- if section.settings.choose_gift_button_label != blank -%}
        <a
          {% if gift_link != blank %}
            href="{{ gift_link }}"
          {% else %}
            role="link" aria-disabled="true"
          {% endif %}
          class="custom-banner__nav-button"
        >
          {{ section.settings.choose_gift_button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

  <div
    class="custom-banner__hero"
    {% if section.settings.background_image %}
      style="background-image: url({{ section.settings.background_image | image_url: width: 1600 }});"
    {% endif %}
  >
    <div class="custom-banner__container custom-banner__hero-inner">
      {%- if section.settings.heading != blank -%}
        <h1 class="custom-banner__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="custom-banner__description">{{ section.settings.description }}</div>
      {%- endif -%}

      {%- if section.settings.shop_now_button_label != blank -%}
        <a
          {% if shop_link != blank %}
            href="{{ shop_link }}"
          {% else %}
            role="link" aria-disabled="true"
          {% endif %}
          class="custom-banner__shop-now"
        >
          <span>{{ section.settings.shop_now_button_label }}</span>
          <svg
            class="custom-banner__shop-now-arrow"
            width="18"
            height="12"
            viewBox="0 0 18 12"
            fill="none"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M17.5303 6.53033C17.8232 6.23744 17.8232 5.76256 17.5303 5.46967L12.7574 0.696699C12.4645 0.403806 11.9896 0.403806 11.6967 0.696699C11.4038 0.989593 11.4038 1.46447 11.6967 1.75736L15.9393 6L11.6967 10.2426C11.4038 10.5355 11.4038 11.0104 11.6967 11.3033C11.9896 11.5962 12.4645 11.5962 12.7574 11.3033L17.5303 6.53033ZM0 6.75H17V5.25H0V6.75Z"
              fill="currentColor"
            />
          </svg>
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.sub_banner_text != blank -%}
    <div class="custom-banner__strip">
      <p>{{ section.settings.sub_banner_text }}</p>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.custom-banner.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.custom-banner.settings.background_image.label"
    },
    {
      "type": "header",
      "content": "t:sections.custom-banner.settings.header_nav.content"
    },
    {
      "type": "text",
      "id": "nav_announcement_text",
      "label": "t:sections.custom-banner.settings.nav_announcement_text.label",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "choose_gift_button_label",
      "label": "t:sections.custom-banner.settings.choose_gift_button_label.label",
      "default": "Choose gift"
    },
    {
      "type": "url",
      "id": "choose_gift_button_link",
      "label": "t:sections.custom-banner.settings.choose_gift_button_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.custom-banner.settings.header_hero.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.custom-banner.settings.heading.label",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.custom-banner.settings.description.label",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "shop_now_button_label",
      "label": "t:sections.custom-banner.settings.shop_now_button_label.label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "shop_now_button_link",
      "label": "t:sections.custom-banner.settings.shop_now_button_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.custom-banner.settings.header_strip.content"
    },
    {
      "type": "text",
      "id": "sub_banner_text",
      "label": "t:sections.custom-banner.settings.sub_banner_text.label",
      "default": "Sustainable, ethically made clothes in sizes XXS to 6XL"
    }
  ],
  "presets": [
    {
      "name": "t:sections.custom-banner.presets.name"
    }
  ]
}
{% endschema %}
